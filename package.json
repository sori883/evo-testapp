{
  "name": "evo-testapp",
  "version": "0.1.0",
  "private": true,
  "description": "evo（外部 SRE エージェント基盤）の監視・自動修正対象となるサーバーレス ToDo API サンプル",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "pnpm build && cdk deploy --require-approval never",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm synth"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.717.0",
    "@aws-sdk/lib-dynamodb": "^3.717.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@biomejs/biome"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.10.5",
    "aws-cdk": "^2.177.0",
    "aws-cdk-lib": "^2.177.0",
    "constructs": "^10.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
