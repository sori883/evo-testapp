# ローカル/検証用の環境変数サンプル。実値の .env は commit しない（.gitignore 済み）。

# 実行時設定（Lambda では CDK が注入する）
TABLE_NAME=sampleapp-todos
SERVICE_NAME=evo-testapp
STAGE=dev
LOG_LEVEL=info
AWS_REGION=ap-northeast-1

# フォルトインジェクション（平常はすべて OFF）。
# ON にするとエラー増→CloudWatch アラーム発報→evo の診断/修正 PR を再現できる。
FAULT_NULL_DEREF=false   # true で変更系 operation が TypeError（局在バグ）を投げる
FAULT_LATENCY_MS=0       # >0 で各リクエストにレイテンシ注入（API GW Latency p99 を上げる）
FAULT_ERROR_RATE=0       # 0..1。確率的に InjectedFaultError を投げる（Lambda Errors を上げる）
FAULT_DYNAMO_FAIL=false  # true で DynamoDB アクセスを擬似的に失敗させる
